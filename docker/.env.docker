# FKCrypto Docker Environment Configuration
# This file overrides .env values for Docker Compose networking

# Database - Docker service names
DB_HOST=postgres
DB_PORT=5432
DB_NAME=fkcrypto
DB_USER=fkcrypto
DB_PASSWORD=changeme
DATABASE_URL=postgresql://fkcrypto:changeme@postgres:5432/fkcrypto

# Redis - Docker service names
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# Freqtrade - Docker internal URL
FREQTRADE_API_URL=http://freqtrade:8080
FREQTRADE_API_KEY=changeme

# LiteLLM - Docker internal URL
LITELLM_PROXY_URL=http://litellm:4000
LITELLM_MASTER_KEY=sk-litellm-master-key

# Gateway
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000

# Dashboard
DASHBOARD_PORT=8501

# Metrics
METRICS_PORT=9090
GRAFANA_ADMIN_PASSWORD=admin
